# ── SUPABASE ──
# Project URL from Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public key — safe for browser, respects RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# ── PAYSTACK ──
# Secret key — server only, from Paystack dashboard > Settings > API
PAYSTACK_SECRET_KEY=

# Public key — from Paystack dashboard
PAYSTACK_PUBLIC_KEY=

# Public key exposed to browser for checkout
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# ── APP ──
# Full URL of your app — no trailing slash
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to true to run with mock data when Supabase is not configured
NEXT_PUBLIC_DEMO_MODE=true

# ── WAITLIST ──
# Total founding member spots
NEXT_PUBLIC_WAITLIST_GOAL=40

# Current real signup count — update this before each deploy
NEXT_PUBLIC_INITIAL_COUNT=13

# ── SECURITY ──
# Random secret for protecting cron job endpoints — generate with: openssl rand -hex 32
CRON_SECRET=

# Random secret for internal rate limit operations
RATE_LIMIT_SECRET=

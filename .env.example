# Supabase project URL, for browser and server clients.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous public key, safe for browser usage with RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key, server-only for trusted scripts and webhooks.
SUPABASE_SERVICE_ROLE_KEY=

# Paystack secret key, server-only for initialization and webhook verification.
PAYSTACK_SECRET_KEY=

# Paystack public key used by server-created checkout metadata when needed.
PAYSTACK_PUBLIC_KEY=

# Paystack public key, exposed to the browser for checkout flows.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Canonical app URL used in redirects and payment callbacks.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Use mock-backed browser data when Supabase credentials are not configured.
NEXT_PUBLIC_DEMO_MODE=true
